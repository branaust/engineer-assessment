# Star Wars Engineer Assessment - Docker Environment Configuration
# Copy this file to .env and customize as needed
# Run: cp .env.example .env (or copy .env.example .env on Windows)

# Application Settings
APP_NAME=Star Wars API
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_KEY=base64:GENERATE_A_NEW_KEY_AFTER_FIRST_RUN

# Port Configuration (change if you have conflicts)
BACKEND_PORT=8080
FRONTEND_PORT=5173
DB_EXTERNAL_PORT=3307
REDIS_EXTERNAL_PORT=6379

# Database Configuration
DB_DATABASE=starwars
DB_USERNAME=starwars
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# Redis Configuration
REDIS_PASSWORD=null

# Queue and Cache Configuration
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Frontend Configuration
VITE_API_URL=http://localhost:8080/api

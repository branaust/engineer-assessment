# API base URL for the Laravel backend.
# Defaults are set automatically per platform (see src/api/client.ts):
#   iOS simulator:    http://localhost:8080/api
#   Android emulator: http://10.0.2.2:8080/api
#
# Override here when running on a physical device (use your LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.x:8080/api
